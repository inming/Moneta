# 统一换行符为 LF（解决 WSL2 ↔ Windows 跨平台同步问题）
# 所有文本文件在仓库中使用 LF，checkout 时根据平台自动转换

# 默认规则：自动检测文本文件并统一为 LF
* text=auto eol=lf

# 源代码文件
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.json text eol=lf

# Shell 脚本（必须是 LF，否则 WSL2 无法执行）
*.sh text eol=lf

# 配置文件
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.env text eol=lf
*.env.* text eol=lf
.editorconfig text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# 文档
*.md text eol=lf
*.txt text eol=lf

# HTML/CSS
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf
*.less text eol=lf

# SQL
*.sql text eol=lf

# 二进制文件（明确标记为二进制，避免自动转换）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.node binary
